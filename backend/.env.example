PORT=5000
NODE_ENV=development

# PostgreSQL connection string
# Local:   postgresql://user:password@localhost:5432/qrvehicle
# Render:  provided in dashboard
# Railway: provided in dashboard
DATABASE_URL="postgresql://postgres:password@localhost:5432/qrvehicle?schema=public"

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=24h

# CORS — frontend origin(s), comma-separated for multiple
FRONTEND_URL=http://localhost:3000

# Base URL used to build QR code URLs (set to your production frontend domain)
BASE_URL=http://localhost:3000
